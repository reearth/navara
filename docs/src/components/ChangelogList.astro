---
// Component that fetches release information from GitHub API and displays changelog
interface Props {
  owner: string;
  repo: string;
  limit?: number;
}

const { owner, repo, limit = 10 } = Astro.props;

interface GitHubRelease {
  tag_name: string;
  name: string;
  published_at: string;
  body: string;
  html_url: string;
}

let releases: GitHubRelease[] = [];
let error: string | null = null;

try {
  const response = await fetch(
    `https://api.github.com/repos/${owner}/${repo}/releases?per_page=${limit}`,
    {
      headers: {
        'Accept': 'application/vnd.github.v3+json',
        'User-Agent': 'navara-developer-docs'
      }
    }
  );

  if (!response.ok) {
    throw new Error(`GitHub API error: ${response.status}`);
  }

  releases = await response.json();
} catch (e) {
  error = e instanceof Error ? e.message : 'Failed to fetch releases';
  console.error('Error fetching GitHub releases:', error);
}
---

{error ? (
  <div class="error-message">
    <p>リリース情報の取得に失敗しました: {error}</p>
    <p>GitHubで直接確認してください: <a href={`https://github.com/${owner}/${repo}/releases`} target="_blank" rel="noopener noreferrer">Releases</a></p>
  </div>
) : releases.length === 0 ? (
  <p>リリース情報がありません。</p>
) : (
  <div class="changelog-list">
    {releases.map((release) => {
      const formattedBody = release.body 
        ? release.body
            .replace(/\n/g, '<br>')
            .replace(/#{1,6}\s(.+)/g, '<strong>$1</strong>')
            .replace(/\*\*(.+?)\*\*/g, '<strong>$1</strong>')
            .replace(/\*(.+?)\*/g, '<em>$1</em>')
        : '';
      
      return (
        <article class="release">
          <header>
            <h3>
              <a href={release.html_url} target="_blank" rel="noopener noreferrer">
                {release.name || release.tag_name}
              </a>
            </h3>
            <div class="release-meta">
              <span class="tag">{release.tag_name}</span>
              <time datetime={release.published_at}>
                {new Date(release.published_at).toLocaleDateString('ja-JP', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric'
                })}
              </time>
            </div>
          </header>
          <div class="release-body" set:html={formattedBody} />
        </article>
      );
    })}
  </div>
)}

<style>
  .error-message {
    padding: 1rem;
    background: var(--sl-color-bg-nav);
    border: 1px solid var(--sl-color-hairline);
    border-radius: 8px;
    margin: 1rem 0;
  }

  .error-message p {
    margin: 0.5rem 0;
  }

  .error-message a {
    color: var(--sl-color-accent);
  }

  .changelog-list {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .release {
    border: 1px solid var(--sl-color-hairline);
    border-radius: 8px;
    padding: 1.5rem;
    background: var(--sl-color-bg-nav);
  }

  .release header {
    margin-bottom: 1rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid var(--sl-color-hairline);
  }

  .release h3 {
    margin: 0 0 0.5rem 0;
    font-size: 1.5rem;
  }

  .release h3 a {
    color: var(--sl-color-white);
    text-decoration: none;
  }

  .release h3 a:hover {
    color: var(--sl-color-accent);
  }

  .release-meta {
    display: flex;
    gap: 1rem;
    align-items: center;
    font-size: 0.9rem;
    color: var(--sl-color-gray-2);
  }

  .tag {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    background: var(--sl-color-accent);
    color: var(--sl-color-black);
    border-radius: 4px;
    font-weight: 600;
    font-size: 0.85rem;
  }

  .release-body {
    color: var(--sl-color-gray-2);
    line-height: 1.6;
  }

  .release-body :global(strong) {
    color: var(--sl-color-white);
    font-weight: 600;
  }

  .release-body :global(em) {
    font-style: italic;
  }
</style>
