---
import SimpleShowcaseCard from './SimpleShowcaseCard.astro';
import SimpleGrid from './SimpleGrid.astro';
import showcaseData from '../data/showcase.json';
import { getLocalizedField } from '../utils/translations';

const { locale } = Astro.locals.starlightRoute;
---

<SimpleGrid>
  {showcaseData.map((item) => (
    <SimpleShowcaseCard
      title={getLocalizedField(item, 'title', locale)}
      href={item.href}
      thumbnail={item.thumbnail}
      description={getLocalizedField(item, 'description', locale)}
    />
  ))}
</SimpleGrid>
