---
interface Props {
  columns?: number;
  gap?: string;
}

const { columns = "repeat(auto-fit, minmax(min(100%, 300px), 1fr))", gap = "1.5rem" } = Astro.props;
---

<div class="simple-grid">
  <slot />
</div>

<style define:vars={{ columns, gap }}>
  .simple-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(100%, 300px), 1fr));
    gap: var(--gap);
    margin: 2rem 0;
    align-items: stretch;
  }

  @media (max-width: 768px) {
    .simple-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
