{
  "name": "@navara/three",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "main": "dist/three.umd.cjs",
  "module": "dist/three.js",
  "types": "dist/index.d.ts",
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "start": "vite",
    "dev": "vite -c vite.config.example.ts --host",
    "build": "tsc && vite build",
    "build:example": "tsc && vite build -c vite.config.example.ts",
    "preview": "vite preview",
    "test": "vitest --passWithNoTests",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check --ignore-path .gitignore ."
  },
  "license": "MIT OR Apache-2.0",
  "peerDependencies": {
    "three": "^0.170.0"
  },
  "dependencies": {
    "three": "^0.171.0",
    "lodash-es": "^4.17.21",
    "@navara/engine": "file:../../crates/navara_wasm/pkg",
    "@navara/engine-worker": "file:../../crates/navara_wasm_worker/pkg",
    "stats.js": "^0.17.0",
    "three-stdlib": "^2.34.0",
    "tiny-invariant": "^1.3.3",
    "tweakpane": "^4.0.5",
    "workerpool": "^9.2.0"
  },
  "devDependencies": {
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.9.0",
    "@types/three": "^0.170.0",
    "@typescript-eslint/utils": "^8.14.0",
    "eslint": "^9.14.0",
    "eslint-config-reearth": "^0.3.6",
