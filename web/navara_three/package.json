    "geojson": "^0.5.0",
    "navara": "file:../../crates/navara_wasm/pkg",
    "pbf": "^3.2.1",
    "stats.js": "^0.17.0",
    "three-stdlib": "^2.29.4",
    "tweakpane": "^4.0.4"
  },
  "devDependencies": {
    "@types/earcut": "^2.1.4",
    "@types/mapbox__vector-tile": "^1.3.4",
    "@types/pbf": "^3.0.5",
