{
  "name": "@navara/three",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "main": "dist/index.umd.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "start": "vite",
    "dev": "vite -c vite.config.example.ts --host",
    "build": "tsc && vite build",
    "build:example": "tsc && vite build -c vite.config.example.ts",
    "preview": "vite preview",
    "test": "vitest --passWithNoTests --watch=false",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "format": "prettier --write --ignore-path ../../.gitignore .",
    "format:check": "prettier --check --ignore-path ../../.gitignore ."
  },
  "license": "MIT OR Apache-2.0",
  "peerDependencies": {
    "three": "^0.174.0"
  },
  "dependencies": {
    "@navara/core": "workspace:*",
    "@navara/worker": "workspace:*",
    "postprocessing": "^6.36.7",
    "stats.js": "^0.17.0",
    "three-stdlib": "^2.35.14",
    "troika-three-text": "^0.52.3"
  },
  "devDependencies": {
    "@tweakpane/core": "^2.0.5",
    "@types/stats.js": "^0.17.3",
    "@types/three": "^0.174.0",
    "ajv": "^8.17.1",
    "three": "^0.174.0",
    "tweakpane": "^4.0.5",
    "vite-plugin-glsl": "^1.3.3",
    "vite-plugin-virtual-mpa": "^1.12.1"
  }
}
