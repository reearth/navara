{
  "name": "@navara/three",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "main": "dist/index.umd.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "start": "vite",
    "dev": "vite -c vite.config.example.ts --host",
    "build": "vite build -c vite.config.ts",
    "build:dev": "vite build --mode development",
    "build:dev:watch": "pnpm build:dev --watch",
    "build:example": "tsc && vite build -c vite.config.example.ts",
    "preview": "vite preview",
    "test": "vitest --passWithNoTests --watch=false",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "format": "prettier --write --ignore-path ../../.gitignore --ignore-path ../../.prettierignore .",
    "format:check": "prettier --check --ignore-path ../../.gitignore --ignore-path ../../.prettierignore .",
    "screenshots": "tsx scripts/generate-screenshots.ts"
  },
  "license": "MIT OR Apache-2.0",
  "peerDependencies": {
    "three": "^0.183.1",
    "postprocessing": "^6.38.3"
  },
  "dependencies": {
