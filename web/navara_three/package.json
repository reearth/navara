{
  "name": "@navara/three",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "main": "dist/index.umd.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "start": "vite",
    "dev": "vite -c vite.config.example.ts --host",
    "dev:example": "vite -c vite.config.example.ts --host",
    "build": "tsc --project tsconfig.build.json && vite build",
    "build:dev": "vite build --mode development",
    "build:dev:watch": "pnpm build:dev --watch",
    "build:example": "tsc && vite build -c vite.config.example.ts",
    "preview": "vite preview",
    "test": "vitest --passWithNoTests --watch=false",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "format": "prettier --write --ignore-path ../../.gitignore .",
    "format:check": "prettier --check --ignore-path ../../.gitignore .",
    "screenshots": "tsx scripts/generate-screenshots.ts"
  },
  "license": "MIT OR Apache-2.0",
  "peerDependencies": {
    "three": "^0.178.0"
  },
  "dependencies": {
    "@navara/core": "workspace:*",
    "@navara/three_api": "workspace:*",
    "@navara/three_csm": "workspace:*",
    "@navara/worker": "workspace:*",
    "@takram/three-atmosphere": "^0.14.0",
    "@takram/three-clouds": "^0.5.0",
    "@takram/three-geospatial": "^0.4.0",
    "@takram/three-geospatial-effects": "^0.4.1",
    "n8ao": "^1.10.1",
    "postprocessing": "^6.37.8",
    "stats.js": "^0.17.0",
    "three-stdlib": "^2.36.0",
    "troika-three-text": "^0.52.4"
  },
  "devDependencies": {
    "@navara/three_react": "workspace:*",
    "@playwright/test": "^1.55.0",
    "@tweakpane/core": "^2.0.5",
    "@types/stats.js": "^0.17.4",
    "@types/three": "^0.178.0",
    "ajv": "^8.17.1",
    "playwright": "^1.55.0",
    "three": "^0.178.0",
    "tsx": "^4.20.5",
    "tweakpane": "^4.0.5",
    "vite-plugin-glsl": "^1.5.1",
    "vite-plugin-static-copy": "^3.1.2",
    "vite-plugin-virtual-mpa": "^1.12.1"
  }
}
