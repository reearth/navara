    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-glsl": "^1.3.0",
    "vite-plugin-top-level-await": "^1.4.4",
    "vite-plugin-virtual-mpa": "^1.12.1",
