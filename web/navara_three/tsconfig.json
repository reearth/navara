{
  "extends": "../tsconfig.common.json",
  "compilerOptions": {
    "paths": {
      "@navara/three": ["./src"],
      "@navara/three_api": ["../navara_three_api/src"],
      "@navara/core": ["../navara_core/src"],
      "@navara/worker": ["../navara_worker/src"],
      "@navara/csm": ["../navara_csm/src"],
      "@navara/three_react": ["../navara_react/src"],
      "@navara/engine": ["../../node_modules/navara_wasm"],
      "@navara/engine-worker": ["../../node_modules/navara_wasm_worker"],
      "@navara/engine-api": ["../../node_modules/navara_wasm_api"],
      "@shaders/*": ["../../shaders"],
      "@/components/*": ["./example/components/*"],
      "@/lib/*": ["./example/lib/*"],
      "@/lib/utils": ["./example/lib/utils"]
    }
  },
  "include": ["src", "example"],
  "exclude": ["./dist", "./node_modules"],
  "references": [
    {
      "path": "./tsconfig.node.json"
    }
  ]
}
