{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    /* Bundler mode */
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "noEmit": true,
    /* Linting */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "verbatimModuleSyntax": true,
    "paths": {
      "@navara/engine": ["../node_modules/navara_wasm"],
      "@navara/engine-worker": ["../node_modules/navara_wasm_worker"],
      "@navara/engine-api": ["../node_modules/navara_wasm_api"],
      "@shaders/*": ["../shaders"]
    },
  },
}
