#ifndef ELLIPSOID_GLSL
#define ELLIPSOID_GLSL

#define WGS84_A 6378137.0
#define WGS84_B 6356752.3142451793

const vec3 WGS84_RADII = vec3(WGS84_A, WGS84_A, WGS84_B);
const vec3 ONE_OVER_WGS84_RADII = 1.0 / vec3(WGS84_A, WGS84_A, WGS84_B);
const vec3 ONE_OVER_WGS84_RADII_SQUARED = 1.0 / vec3(WGS84_A * WGS84_A, WGS84_A * WGS84_A, WGS84_B * WGS84_B);

const float WGS84_E2 = 0.00669438; // ((WGS84_A * WGS84_A) - (WGS84_B * WGS84_B)) / (WGS84_A * WGS84_A)
const float WGS84_E2_SECOND = 0.00673950; // ((WGS84_A * WGS84_A) - (WGS84_B * WGS84_B)) / (WGS84_B * WGS84_B)

const float WGS84_FLATTENING = 0.00335281; // (WGS84_A - WGS84_B) / WGS84_A
const float WGS84_FLATTENING_RECIPROCAL = 298.257223563; // 1.0 / WGS84_FLATTENING


#endif // ELLIPSOID_GLSL