{
  "name": "navara",
  "version": "0.0.0",
  "private": true,
  "description": "",
  "engines": {
    "pnpm": "10.16.1"
  },
  "packageManager": "pnpm@10.16.1",
  "scripts": {
    "navara_three": "pnpm -C web/navara_three",
    "integration-tests": "pnpm -filter './web/integration-tests/**'",
    "star": "pnpm navara_three start",
    "dev": "pnpm navara_three dev",
    "dev:integration": "pnpm integration-tests -r run dev",
    "preview": "pnpm navara_three preview",
    "build": "pnpm --filter-prod './web/**' --filter-prod '!./web/integration-tests/**' run build",
    "build:common:dev": "NODE_ENV=development pnpm -r --parallel run build:dev:watch",
    "build:example": "pnpm build && pnpm -r run build:example",
    "build:integration": "pnpm integration-tests -r run build",
    "test": "pnpm -r run test",
    "format": "pnpm -r run format",
    "format:check": "pnpm -r run format:check",
    "lint": "pnpm -r run lint",
    "lint:check": "pnpm -r run lint:check"
  },
  "keywords": [],
  "author": "",
  "license": "MIT OR Apache-2.0",
  "dependencies": {
    "lodash-es": "^4.17.21",
    "tiny-invariant": "^1.3.3"
  },
  "devDependencies": {
    "@microsoft/api-extractor": "^7.52.8",
    "unplugin-dts": "^1.0.0-beta.6",
    "@types/geojson": "^7946.0.16",
    "@types/lodash-es": "^4.17.12",
    "@types/node": "^22.18.5",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@typescript-eslint/utils": "^8.44.0",
    "@vitejs/plugin-react": "^5.0.3",
    "eslint": "^9.35.0",
    "eslint-config-reearth": "^0.3.8",
    "@navara/engine": "workspace:*",
    "@navara/engine-api": "workspace:*",
    "@navara/engine-worker": "workspace:*",
    "prettier": "^3.6.2",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "shadcn": "^3.4.0",
    "typescript": "^5.9.2",
    "vite": "^7.1.5",
    "vite-tsconfig-paths": "^5.1.4",
    "vite-plugin-wasm": "3.5.0",
    "vite-plugin-top-level-await": "1.6.0",
    "vitest": "^3.2.4"
  }
}