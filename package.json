    "lodash-es": "4.18.1",
    "tiny-invariant": "1.3.3"
  },
  "devDependencies": {
    "@microsoft/api-extractor": "7.58.2",
    "@navara/engine": "workspace:*",
    "@navara/engine-api": "workspace:*",
    "@navara/engine-font-worker": "workspace:*",
    "@navara/engine-worker": "workspace:*",
    "@types/geojson": "7946.0.16",
