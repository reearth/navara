{
  "name": "navara",
  "version": "0.0.0",
  "private": true,
  "description": "",
  "engines": {
    "node": ">=20",
    "pnpm": "10.32.1"
  },
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "navara_three": "pnpm -C web/navara_three",
    "integration-tests": "pnpm -filter './web/integration-tests/**'",
    "star": "pnpm navara_three start",
    "dev": "pnpm navara_three dev",
    "dev:integration": "pnpm integration-tests -r run dev",
    "preview": "pnpm navara_three preview",
    "build": "pnpm --filter-prod './web/**' --filter-prod '!./web/integration-tests/**' run build",
    "build:common:dev": "NODE_ENV=development pnpm -r --parallel run build:dev:watch",
    "build:example": "pnpm build && pnpm -r run build:example",
    "build:integration": "pnpm integration-tests -r run build",
    "test": "pnpm -r run test",
    "format": "pnpm -r run format",
    "format:check": "pnpm -r run format:check",
    "lint": "pnpm -r run lint",
    "lint:check": "pnpm -r run lint:check"
  },
  "keywords": [],
  "author": "",
  "license": "MIT OR Apache-2.0",
  "dependencies": {
    "lodash-es": "4.17.23",
    "tiny-invariant": "1.3.3"
  },
  "devDependencies": {
    "@microsoft/api-extractor": "7.57.7",
    "@navara/engine": "workspace:*",
    "@navara/engine-api": "workspace:*",
    "@navara/engine-font-worker": "workspace:*",
    "@navara/engine-worker": "workspace:*",
    "@types/geojson": "7946.0.16",
    "@types/lodash-es": "4.17.12",
    "@types/node": "24.12.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/utils": "8.57.1",
    "@vitejs/plugin-react": "6.0.1",
    "eslint": "9.39.4",
    "eslint-config-reearth": "0.3.8",
    "jsdom": "29.0.1",
    "prettier": "3.8.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "4.1.0",
    "typescript": "5.9.3",
    "unplugin-dts": "1.0.0-beta.6",
    "vite": "8.0.1",
    "vite-plugin-top-level-await": "1.6.0",
    "vite-plugin-wasm": "3.6.0",
    "vite-tsconfig-paths": "6.1.1",
    "vitest": "4.1.0"
  }
