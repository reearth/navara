  "engines": {
    "node": "v25.9.0",
    "pnpm": "10.33.0"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "navara_three": "pnpm -C web/navara_three",
    "integration-tests": "pnpm -filter './web/integration-tests/**'",
    "star": "pnpm navara_three start",
    "dev": "pnpm navara_three dev",
    "dev:integration": "pnpm integration-tests -r run dev",
    "preview": "pnpm navara_three preview",
    "build": "pnpm --filter-prod './web/**' --filter-prod '!./web/integration-tests/**' run build",
    "build:common:dev": "NODE_ENV=development pnpm -r --parallel run build:dev:watch",
    "build:example": "pnpm build && pnpm -r run build:example",
    "build:integration": "pnpm integration-tests -r run build",
    "test": "pnpm --filter './web/**' -r run test",
    "format": "pnpm --filter './web/**' -r run format",
    "format:check": "pnpm --filter './web/**' -r run format:check",
    "lint": "pnpm --filter './web/**' -r run lint",
    "lint:check": "pnpm --filter './web/**' -r run lint:check",
    "dev:docs": "pnpm -C docs dev",
    "build:docs": "pnpm -C docs build",
    "preview:docs": "pnpm -C docs preview"
  },
  "keywords": [],
  "author": "",
  "license": "MIT OR Apache-2.0",
