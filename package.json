    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@typescript-eslint/utils": "8.58.1",
    "@vitejs/plugin-react": "6.0.1",
    "eslint": "10.2.0",
    "eslint-config-reearth": "0.3.8",
    "jsdom": "29.0.2",
    "prettier": "3.8.2",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "shadcn": "4.2.0",
    "typescript": "6.0.2",
    "unplugin-dts": "1.0.0-beta.6",
    "vite": "8.0.8",
