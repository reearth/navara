{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>reearth/renovate-config",
    ":pinVersions"
  ],
  "separateMinorPatch": true,
  "packageRules": [
    {
      "matchDepTypes": [
        "peerDependencies"
      ],
      "rangeStrategy": "widen"
    },
    {
      "matchPackageNames": [
        "node"
      ],
      "enabled": false
    },
    {
      "matchManagers": ["npm"],
      "matchUpdateTypes": ["patch"],
      "groupName": "npm patch updates",
      "groupSlug": "npm-patch",
      "schedule": ["before 3:00 am on monday"]
    }
  ]
}